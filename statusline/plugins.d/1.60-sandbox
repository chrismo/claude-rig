#!/bin/bash
# Segment: sandbox status

muted_green="\033[2;32m"
muted_red="\033[2;31m"
color_reset="\033[2;37m"

project_dir="${CLAUDE_PROJECT_DIR:-}"
# settings.local.json is actually local to the dir launched in,
# but we always launch from project root
settings_file="${project_dir}/.claude/settings.local.json"

if [[ ! -f "$settings_file" ]]; then
  exit 0
fi

sandbox_enabled=$(super -f line -c 'coalesce(sandbox.enabled, false)' "$settings_file")
if [[ "$sandbox_enabled" == "true" ]]; then
  auto=$(super -f line -c 'coalesce(sandbox.autoAllowBashIfSandboxed, false)' "$settings_file")
  if [[ "$auto" == "true" ]]; then
    echo -e "${muted_green}sandbox: auto${color_reset}"
  else
    echo "sandbox: on"
  fi
else
  echo -e "${muted_red}sandbox: off${color_reset}"
fi
