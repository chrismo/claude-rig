#!/bin/bash
# Segment: lines added/removed
input="${CLAUDE_STATUS_INPUT:-/tmp/claude-status-input.json}"

muted_green="\033[2;32m"
muted_red="\033[2;31m"
color_reset="\033[2;37m"

added=$(super -f line -c 'coalesce(cost.total_lines_added, 0)' "$input")
removed=$(super -f line -c 'coalesce(cost.total_lines_removed, 0)' "$input")

echo -e "${muted_green}+${added}${color_reset}/${muted_red}-${removed}${color_reset}"
