#!/bin/bash
# Segment: session cost and duration
input="${CLAUDE_STATUS_INPUT:-/tmp/claude-status-input.json}"

cost_usd=$(super -f line -c 'coalesce(cost.total_cost_usd, 0)' "$input")
duration_ms=$(super -f line -c 'coalesce(cost.total_duration_ms, 0)' "$input")
api_duration_ms=$(super -f line -c 'coalesce(cost.total_api_duration_ms, 0)' "$input")

formatted_duration=$(super -f line -c "values $duration_ms / 1000 | values bucket(f'{this}s'::duration, 1m)")
formatted_api_duration=$(super -f line -c "values $api_duration_ms / 1000 | values bucket(f'{this}s'::duration, 1m)")

printf "\$%.2f | %s (api: %s)" "$cost_usd" "$formatted_duration" "$formatted_api_duration"
